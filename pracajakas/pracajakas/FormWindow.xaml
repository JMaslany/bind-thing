<Window x:Class="pracajakas.FormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pracajakas"
        mc:Ignorable="d"
        Title="FormWindow" Height="400" Width="300">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="2*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">Imie</TextBlock>
        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">Nazwisko</TextBlock>
        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">Nr. Telefonu</TextBlock>
        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">Wiek</TextBlock>

        <TextBox Grid.Row="0" Grid.Column="1" Height="40px" Width="170px"></TextBox>
        <TextBox Grid.Row="1" Grid.Column="1" Height="40px" Width="170px"></TextBox>
        <TextBox Grid.Row="2" Grid.Column="1" Height="40px" Width="170px"></TextBox>
        <TextBox Grid.Row="3" Grid.Column="1" Height="40px" Width="170px"></TextBox>

        <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Width="200px" Height="50px" Click="Button_Click">Dodaj</Button>
    </Grid>
</Window>
