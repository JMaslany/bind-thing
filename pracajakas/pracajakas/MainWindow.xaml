<Window x:Class="pracajakas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pracajakas"
        mc:Ignorable="d"
        Title="MainWindow" Height="400" Width="600">

    <StackPanel Orientation="Vertical">
        <Menu>
            <MenuItem Header="Plik">
                <MenuItem Header="Zapisz JSON" Click="MenuSave"/>
                <MenuItem Header="Wczytaj JSON" Click="MenuRead"/>
            </MenuItem>
            <MenuItem Header="Dane">
                <MenuItem Header="Dodaj" Click="AddData"/>
                <MenuItem Header="Usun" Click="DeleteData"/>
                <MenuItem Header="Edytuj" Click="EditData"/>
            </MenuItem>
        </Menu>
        <DataGrid x:Name="DataDisplay">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Imie" Binding="{Binding Imie}" Width="*"/>
                <DataGridTextColumn Header="Nazwisko"  Binding="{Binding Nazwisko}"  Width="*"/>
                <DataGridTextColumn Header="Nr. Telefonu" Binding="{Binding NrTel}" Width="*"/>
                <DataGridTextColumn Header="Wiek" Binding="{Binding Wiek}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
    
</Window>
